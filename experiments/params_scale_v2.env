# Fair v2 scalability parameters

EMERGENCY_RATE=10m

# Shared shaping budget for both baseline and SDNV
BASELINE_FLAT_SHAPING=1
SDNV_TOTAL_RATE=40mbit
SDNV_TOTAL_CEIL=40mbit
SDNV_USE_FQ_CODEL=1

# SDNV class tuning
SDNV_HP_RATE=12mbit
SDNV_HP_CEIL=40mbit
SDNV_BE_RATE=28mbit
SDNV_BE_CEIL=40mbit

# Keep aggregate background load constant across vehicle counts
SDNV_BG_TOTAL_MBIT=30

# Emergency-class ports: emergency throughput, emergency latency, dissemination
SDNV_PRIORITY_PORTS=5001,5003,6000
SDNV_EMERGENCY_PORT=5001
SDNV_BEST_EFFORT_PORT=5002
SDNV_LATENCY_PORT=5003
SDNV_BACKGROUND_LATENCY_PORT=5004
SDNV_EMAPT_PORT=6000
SDNV_LATENCY_INTERVAL=0.2

# Sweep definition
SDNV_START=5
SDNV_STEP=5
SDNV_END=20

# Topology/mobility
SDNV_AREA_SIZE=1000
SDNV_SPEED_KMH=60
SDNV_WIFI_MODE=g
SDNV_USE_BOTH_APS=1
SDNV_AUTO_ASSOCIATION=1

# Flow timing
SDNV_DURATION=60
SDNV_WARMUP=10
