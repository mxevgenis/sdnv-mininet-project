# Scalability sweep parameters (vehicles 5,10,15,20)

EMERGENCY_RATE=10m

# SDNV shaping (recommended)
SDNV_HP_RATE=15mbit
SDNV_HP_CEIL=40mbit
SDNV_BE_RATE=15mbit
SDNV_BE_CEIL=40mbit

# Sweep definition
SDNV_START=5
SDNV_STEP=5
SDNV_END=20

# Topology/mobility
SDNV_AREA_SIZE=1000
SDNV_SPEED_KMH=60
SDNV_WIFI_MODE=g

# Flow duration (seconds)
SDNV_DURATION=60

# Warm-up period before measurements (seconds)
SDNV_WARMUP=5
