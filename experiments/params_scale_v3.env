# Trigger-based v3 scalability parameters

EMERGENCY_RATE=10m

# Common egress budget for both scenarios before/after the trigger
BASELINE_FLAT_SHAPING=1
SDNV_TOTAL_RATE=40mbit
SDNV_TOTAL_CEIL=40mbit
SDNV_USE_FQ_CODEL=1

# SDNV post-trigger tuning: protect emergency traffic, leave a small residual
# best-effort channel instead of dropping it entirely.
SDNV_HP_RATE=20mbit
SDNV_HP_CEIL=40mbit
SDNV_BE_RATE=1mbit
SDNV_BE_CEIL=2mbit

# Non-emergency vehicles keep a fixed aggregate background load.
SDNV_BG_TOTAL_MBIT=20

# Emergency-class ports: throughput, emergency latency, dissemination
SDNV_PRIORITY_PORTS=5001,5003,6000
SDNV_EMERGENCY_PORT=5001
SDNV_BEST_EFFORT_PORT=5002
SDNV_LATENCY_PORT=5003
SDNV_BACKGROUND_LATENCY_PORT=5004
SDNV_EMAPT_PORT=6000
SDNV_LATENCY_INTERVAL=0.2
SDNV_EMAPT_BG_DURATION=10

# Sweep definition
SDNV_START=2
SDNV_STEP=2
SDNV_END=10

# Topology / mobility
SDNV_AREA_SIZE=1000
SDNV_SPEED_KMH=60
SDNV_WIFI_MODE=g
SDNV_USE_BOTH_APS=1
SDNV_AUTO_ASSOCIATION=1

# Flow timing
SDNV_DURATION=60
SDNV_WARMUP=10
