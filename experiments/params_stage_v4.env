# Cooperative staged ECM v4 parameters

EMERGENCY_RATE=10m

# 5-vehicle initial experiment: 1 emergency vehicle + 4 helpers
SDNV_NUM_VEHICLES=5

# Emergency vehicle shaping
BASELINE_FLAT_SHAPING=1
SDNV_TOTAL_RATE=40mbit
SDNV_TOTAL_CEIL=40mbit
SDNV_EMERGENCY_HP_RATE=40mbit
SDNV_EMERGENCY_HP_CEIL=40mbit
SDNV_EMERGENCY_BE_RATE=0.100mbit
SDNV_EMERGENCY_BE_CEIL=0.100mbit
SDNV_USE_FQ_CODEL=1

# Helper-node offered load model
SDNV_HELPER_TOTAL_MBIT=12.5
SDNV_HELPER_MIN_UDP_MBIT=0.5
SDNV_STAGE_TARGETS=20,40,60,80

# Ports
SDNV_EMERGENCY_PORT=5001
SDNV_BEST_EFFORT_PORT=5002
SDNV_LATENCY_PORT=5003
SDNV_BACKGROUND_LATENCY_PORT=5004
SDNV_COOP_UDP_PORT=5005
SDNV_HELPER_UDP_PORT_BASE=5100
SDNV_EMAPT_PORT=6000
SDNV_EMERGENCY_PRIORITY_PORTS=5001,5003,6000

# Topology / mobility
SDNV_AREA_SIZE=1000
SDNV_SPEED_KMH=60
SDNV_WIFI_MODE=g
SDNV_USE_BOTH_APS=1
SDNV_AUTO_ASSOCIATION=1

# Flow timing
SDNV_DURATION=60
SDNV_WARMUP=10
SDNV_LATENCY_INTERVAL=0.2
SDNV_EMAPT_BG_DURATION=10
