# Base experiment parameters (single scenario or 5-run averages)

EMERGENCY_RATE=10m

# SDNV shaping (recommended)
SDNV_HP_RATE=15mbit
SDNV_HP_CEIL=40mbit
SDNV_BE_RATE=15mbit
SDNV_BE_CEIL=40mbit

# Topology/mobility
SDNV_NUM_VEHICLES=4
SDNV_AREA_SIZE=100
SDNV_SPEED_KMH=60
SDNV_WIFI_MODE=g

# Flow duration (seconds)
SDNV_DURATION=60

# Repeat count for run_5g_be1540_5x.sh
RUNS=5
